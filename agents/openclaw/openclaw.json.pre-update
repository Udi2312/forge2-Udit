{
  "agents": {
    "defaults": {
      "model": {
        "primary": "eastrouter/z-ai/glm-5.1"
      },
      "workspace": "D:\\forge2-UditBansal"
    }
  },
  "channels": {
    "slack": {
      "accounts": {
        "default": {
          "appToken": "${SLACK_APP_TOKEN}",
          "botToken": "${SLACK_BOT_TOKEN}",
          "enabled": true,
          "groupPolicy": "allowlist"
        }
      },
      "enabled": true
    }
  },
  "models": {
    "providers": {
      "eastrouter": {
        "api": "openai-chatgpt-responses",
        "apiKey": "${EASTROUTER_API_KEY}",
        "baseUrl": "https://api.eastrouter.com/v1",
        "models": [
          {
            "id": "z-ai/glm-5.1",
            "name": "z-ai/glm-5.1",
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 4096
          }
        ]
      }
    }
  }
}
